# simplicio-loop-oss configuration. Environment variables with the same
# names override these values; a project's PROFILE.md "Tunables" section
# overrides config.env. No secrets belong in this file.
DEFAULT_UPSTREAM=NousResearch/hermes-agent

# PRIMARY KPI: merge rate (merged/opened), not volume.
DAILY_PR_TARGET=10          # hard cap per day per project
DAILY_PR_HEALTHY=5          # healthy default is 3-5; exceed only with a strong backlog
MAX_OPEN_UNREVIEWED=25      # pause new PRs at/above this many unreviewed
STALE_CLOSE_DAYS=4          # guarded auto-close threshold (PLAYBOOK Phase 2.4)
STALE_PING_DAYS=14          # one polite ping on our PRs with zero interaction
MAX_SALVAGES_PER_DAY=1      # Phase 3c cap
DIFF_LINES_TARGET=250       # rethink scope above ~250 changed lines
RUN_INTERVAL_MINUTES=10     # suggested scheduler cadence
