# simplicio-loop-oss configuration. Environment variables with the same
# names override these values; a project's PROFILE.md "Tunables" section
# overrides config.env. No secrets belong in this file.
DEFAULT_UPSTREAM=NousResearch/hermes-agent
DAILY_PR_TARGET=10
MAX_OPEN_UNREVIEWED=25
STALE_CLOSE_DAYS=4
