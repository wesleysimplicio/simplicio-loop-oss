# simplicio-loop-oss configuration. Environment variables with the same
# names override these values; a project's PROFILE.md "Tunables" section
# overrides config.env. No secrets belong in this file.
DEFAULT_UPSTREAM=NousResearch/hermes-agent

# PRIMARY KPI: merge rate (merged/opened), not volume.
DAILY_PR_TARGET=10          # hard cap per day per project
DAILY_PR_HEALTHY=5          # healthy default is 3-5; exceed only with a strong backlog
MAX_OPEN_UNREVIEWED=5       # pause new PRs at/above this many unreviewed (hermes profile overrides to 25)
STALE_CLOSE_DAYS=0          # 0 = auto-close DISABLED (safe default: most projects review in weeks;
                            # closing our own PRs early is self-harm). Enable per project in
                            # PROFILE.md Tunables only under real queue pressure (hermes sets 4).
STALE_PING_DAYS=14          # one polite ping on our PRs with zero interaction
MAX_SALVAGES_PER_DAY=1      # Phase 3c cap
DIFF_LINES_TARGET=250       # rethink scope above ~250 changed lines
RUN_INTERVAL_MINUTES=10     # suggested scheduler cadence

# Newcomer reputation gate — applies to any project where WE have zero merged
# PRs yet. Overridden by nothing except a first merge (then the normal caps
# above apply). Prevents looking like a spam account in a repo that doesn't
# know us yet.
NEWCOMER_DAILY_PR_CAP=2     # max new PRs/day until our first merge in the project
NEWCOMER_MAX_OPEN_UNREVIEWED=3  # queue-gate threshold until our first merge

# Organization-level invocation (SKILL.md "Invocation" — org repo selection).
ORG_REPO_COUNT=3            # flagship repos to auto-select when given an org instead of owner/repo
ORG_RESELECT_ON_BLOCK=true  # a selected repo found structurally blocked (CLA/anti-agent policy)
                            # during its own Phase R is replaced by the next-ranked eligible repo,
                            # keeping ORG_REPO_COUNT active projects for the org
